{
  "name": "@citypay/elements-react",
  "version": "1.0.6-next",
  "description": "React components and hooks for CityPay Elements.",
  "private": false,
  "license": "MIT",
  "author": "CityPay Limited",
  "homepage": "https://github.com/citypay/elements-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/citypay/elements-react.git",
    "directory": "packages/lib"
  },
  "bugs": {
    "url": "https://github.com/citypay/elements-react/issues"
  },
  "keywords": [
    "citypay",
    "payments",
    "payment-elements",
    "react",
    "checkout",
    "card-payments",
    "apple-pay"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "clean": "rimraf dist dist-types",
    "build": "tsup",
    "prepack": "pnpm build",
    "pack:dry-run": "pnpm pack --dry-run",
    "lint": "eslint"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "dependencies": {
    "@citypay/sdk": "^2.1.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}
